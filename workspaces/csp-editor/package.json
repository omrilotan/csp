    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "ts-loader": "^9.5.7",
    "typescript": "^6.0.3",
    "vercel": "^53.2.0",
    "wrangler": "^4.88.0"
  }
